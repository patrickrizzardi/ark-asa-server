# PROD profile — VPS deployment.
# Copy to .env.prod (gitignored), set a STRONG password, then run:
#   docker compose --env-file .env.prod up -d --build

ARK_ADMIN_PASSWORD=use-a-long-random-secret

SESSION_NAME=My PvP Server
MAX_PLAYERS=30

UPDATE_ON_BOOT=1     # stay current — ASA refuses clients on a mismatched server version
SAVE_ON_STOP=1       # always SaveWorld before shutdown
STOP_GRACE_PERIOD=30s # give SaveWorld time to finish before Docker SIGKILLs
ENABLE_BATTLEYE=1    # anti-cheat ON for real PvP
# MODS=928988,930593 # CurseForge mod IDs for your prod server
