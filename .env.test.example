# TEST profile — fast local config iteration.
# Copy to .env.test (gitignored), set the password, then run:
#   docker compose --env-file .env.test up --build

ARK_ADMIN_PASSWORD=change-me

# Treat like a password, identical on every cluster server — never the default "cluster"/"ark".
ARK_CLUSTER_ID=CHANGE-ME-unique-per-cluster-test

SESSION_NAME=ARK-Test
MAX_PLAYERS=10

UPDATE_ON_BOOT=0     # don't check for updates — fastest boot
SAVE_ON_STOP=0       # instant kill on stop — no save wait during test loops
STOP_GRACE_PERIOD=0s # no grace window — Docker insta-stops the container
ENABLE_BATTLEYE=0    # anti-cheat OFF for local testing
ENABLE_ASAAPI=1      # 1 = launch via AsaApiLoader (modded); 0 = vanilla ArkAscendedServer (kill switch)
# MODS=928988        # CurseForge mod IDs — match prod when testing mod-affected settings
                     # ASA API Utils (955333) is added automatically when ENABLE_ASAAPI=1

# --- MariaDB (shared economy store, M2+) ---
# Real values live in .env.test (gitignored). The placeholder values below are safe to commit — replace them in your real .env.test, never use them as-is.
MARIADB_ROOT_PASSWORD=use-a-long-random-root-secret
MARIADB_DATABASE=arkshop
MARIADB_USER=arkshop
MARIADB_PASSWORD=use-a-long-random-appuser-secret

# --- ArkShop DB connection (M2+) ---
# These default to the MARIADB_* values above. Override only when ArkShop connects as a
# different DB user or to a different host than the standard MariaDB app user.
# ARKSHOP_DB_HOST=mariadb
# ARKSHOP_DB_PORT=3306
# ARKSHOP_DB_NAME=arkshop
# ARKSHOP_DB_USER=arkshop
# ARKSHOP_DB_PASS=use-a-long-random-appuser-secret

# --- Optional: publish MariaDB to a host port for external DB access (DataGrip etc.) ---
# Unset (default) -> 127.0.0.1:3307: loopback only, DB is NOT exposed to the network (prod-safe).
# Set to bind all interfaces for remote browsing from another machine:
#   3307         -> host port 3307, all interfaces (3306 is often taken by another DB container)
#   0.0.0.0:3307 -> same, explicit
# MARIADB_HOST_PORT=3307
