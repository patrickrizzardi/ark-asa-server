# TEST profile — fast local config iteration.
# Copy to .env.test (gitignored), set the password, then run:
#   docker compose --env-file .env.test up --build

ARK_ADMIN_PASSWORD=change-me

SESSION_NAME=ARK-Test
MAX_PLAYERS=10

UPDATE_ON_BOOT=0     # don't check for updates — fastest boot
SAVE_ON_STOP=0       # instant kill on stop — no save wait during test loops
STOP_GRACE_PERIOD=0s # no grace window — Docker insta-stops the container
ENABLE_BATTLEYE=0    # anti-cheat OFF for local testing
# MODS=928988        # CurseForge mod IDs — match prod when testing mod-affected settings
