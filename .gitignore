# Secrets / per-environment config (keep the .example templates tracked)
.env*
!.env.test.example
!.env.prod.example

# Plugin configs are seeded from image defaults and then have DB passwords injected at boot.
plugins-config/**

# Game files + saves live in the `ark-game` docker volume, nothing to ignore on disk.

# Plan-status heartbeat overlay (ephemeral; written by /execute-plan, read by Tessa kanban).
.claude/plans/**/status.json

# Generated loot config (regenerate with `bun run tools/gen-loot.ts`); the real home is config/Game.ini.
tools/out/
tools/node_modules/
